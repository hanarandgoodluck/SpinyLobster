# StarDragon 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# Django 配置
DJANGO_SETTINGS_MODULE=config.settings_production
DJANGO_SECRET_KEY=change-this-to-random-secret-key

# 数据库配置（如果使用环境变量方式）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=test_brain_db
DB_USER=root
DB_PASSWORD=583471755a

# AI 模型 API Keys
DEEPSEEK_API_KEY=your-deepseek-api-key-here
QWEN_API_KEY=your-qwen-api-key-here

# Milvus 配置（如果启用）
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Java 分析服务
JAVA_ANALYZER_SERVICE_URL=http://localhost:8089

# Gunicorn 配置
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=300

# 其他配置
PYTHONUNBUFFERED=1
